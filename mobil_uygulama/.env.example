# Mobil Uygulama — Ortam Değişkenleri Şablonu (Flutter)
# Bu dosyayı .env olarak kopyalayın:
#   cp .env.example .env
# .env dosyasını asla Git'e commit ETMEYİN (.gitignore'a eklenmiştir)
#
# Kullanım: flutter_dotenv paketi ile
#   await dotenv.load(fileName: '.env');
#   final url = dotenv.env['SUPABASE_URL']!;

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Supabase projenizin URL'si (Project Settings > API > Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonim (public) API anahtarı
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Google Gemini AI ──────────────────────────────────────────────────────────
# ⚠️ MOBİL UYGULAMADA doğrudan API key kullanmak yerine
# Next.js API Route üzerinden proxy yapmanız önerilir.
# Geliştirme aşaması için buraya eklenmiştir.
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Uygulama Ayarları ────────────────────────────────────────────────────────
# Geliştirme için Next.js backend URL'si
API_BASE_URL=http://localhost:3000/api

# Uygulama ortamı: development | staging | production
APP_ENV=development
